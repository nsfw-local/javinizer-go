# ==============================================================================
# Javinizer Docker Environment Configuration
# ==============================================================================
# Copy this file to .env and customize the values for your environment:
#   cp .env.example .env
#
# Docker Compose will automatically load variables from .env file.
# ==============================================================================

# ------------------------------------------------------------------------------
# User/Group Mapping (Permission Management)
# ------------------------------------------------------------------------------
# Set these to match your host user to avoid permission issues with volumes.
# Run these commands to get your values:
#   id -u    # Get your USER_ID
#   id -g    # Get your GROUP_ID
#
# Default: 1000 (common for first user on Linux systems)
USER_ID=1000
GROUP_ID=1000

# ------------------------------------------------------------------------------
# Port Configuration
# ------------------------------------------------------------------------------
# Host port to expose the Javinizer web UI and API.
# Change this if port 8080 is already in use on your system.
#
# Default: 8080
HOST_PORT=8080

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------
# Set the timezone for the container (affects log timestamps).
# Use IANA timezone format (e.g., America/New_York, Europe/London, Asia/Tokyo)
#
# Default: UTC
TZ=UTC

# ------------------------------------------------------------------------------
# Media Library Path
# ------------------------------------------------------------------------------
# Absolute path to your JAV library on the host system.
# This will be mounted as /media inside the container.
#
# IMPORTANT: Change this to point to your actual JAV library!
# Default: /path/to/your/jav-library (you must change this)
MEDIA_PATH=/path/to/your/jav-library

# ------------------------------------------------------------------------------
# Development Mode (Optional)
# ------------------------------------------------------------------------------
# Enable development mode for frontend hot-reload.
# Only needed if you're developing the web UI.
#
# Uncomment to enable:
# JAVINIZER_DEV_MODE=true
# VITE_API_URL=http://localhost:8080
