# ==============================================================================
# Javinizer Docker Environment Configuration
# ==============================================================================
# Copy this file to .env and customize the values for your environment:
#   cp .env.example .env
#
# Docker Compose will automatically load variables from .env file.
# ==============================================================================

# ------------------------------------------------------------------------------
# User/Group Mapping (Permission Management)
# ------------------------------------------------------------------------------
# Set these to match your host user to avoid permission issues with volumes.
# Run these commands to get your values:
#   id -u    # Get your USER_ID
#   id -g    # Get your GROUP_ID
#
# Default: 1000 (common for first user on Linux systems)
USER_ID=1000
GROUP_ID=1000

# ------------------------------------------------------------------------------
# File Creation Mask (umask)
# ------------------------------------------------------------------------------
# Controls default permissions for newly created files and directories.
# Recommended: 002 (rwxrwxr-x) - allows group write permissions
# Alternative: 022 (rwxr-xr-x) - only owner can write
#
# Uncomment to override config.yaml setting:
# UMASK=002

# ------------------------------------------------------------------------------
# Port Configuration
# ------------------------------------------------------------------------------
# Host port to expose the Javinizer web UI and API.
# Change this if port 8080 is already in use on your system.
#
# Default: 8080
HOST_PORT=8080

# ------------------------------------------------------------------------------
# FlareSolverr Port Configuration
# ------------------------------------------------------------------------------
# Host port to expose FlareSolverr API (container always listens on 8191).
# Keep default unless 8191 is already in use.
#
# Default: 8191
FLARESOLVERR_HOST_PORT=8191

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------
# Set the timezone for the container (affects log timestamps).
# Use IANA timezone format (e.g., America/New_York, Europe/London, Asia/Tokyo)
#
# Default: UTC
TZ=UTC

# ------------------------------------------------------------------------------
# Media Library Path
# ------------------------------------------------------------------------------
# Absolute path to your JAV library on the host system.
# This will be mounted as /media inside the container.
#
# IMPORTANT: Change this to point to your actual JAV library!
# Default: /path/to/your/jav-library (you must change this)
MEDIA_PATH=/path/to/your/jav-library

# ------------------------------------------------------------------------------
# Logging Configuration (Optional)
# ------------------------------------------------------------------------------
# Override log level from config.yaml
# Valid values: debug, info, warn, error
#
# Uncomment to override:
# LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# FlareSolverr Configuration (Optional)
# ------------------------------------------------------------------------------
# Enable/disable through docker-compose service. Use these to tune behavior.
#
# Valid values:
#   FLARESOLVERR_LOG_LEVEL: debug, info, warning, error
#   FLARESOLVERR_LOG_HTML: true, false
#   FLARESOLVERR_CAPTCHA_SOLVER: none
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_LOG_HTML=false
FLARESOLVERR_CAPTCHA_SOLVER=none

# Optional upstream proxy for FlareSolverr browser traffic.
# Examples:
#   FLARESOLVERR_PROXY_URL=http://proxy.example.com:8080
#   FLARESOLVERR_PROXY_URL=socks5://localhost:1080
FLARESOLVERR_PROXY_URL=
FLARESOLVERR_PROXY_USERNAME=
FLARESOLVERR_PROXY_PASSWORD=

# ------------------------------------------------------------------------------
# Container-Level Proxy Environment (Optional)
# ------------------------------------------------------------------------------
# These are passed into javinizer and javinizer-dev containers.
# If set, HTTP client libraries may use them by default.
# Keep NO_PROXY including flaresolverr so local FlareSolverr calls are direct.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,flaresolverr
ALL_PROXY=

# ------------------------------------------------------------------------------
# Development Mode (Optional)
# ------------------------------------------------------------------------------
# Enable development mode for frontend hot-reload.
# Only needed if you're developing the web UI.
#
# Uncomment to enable:
# JAVINIZER_DEV_MODE=true
# VITE_API_URL=http://localhost:8080
