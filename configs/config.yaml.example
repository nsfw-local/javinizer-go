server:
    host: localhost
    port: 8080
api:
    security:
        # Allowed directories for scanning/browsing (empty = no allowlist restriction)
        # Supports ~ for home directory expansion
        allowed_directories: []
        # Denied directories are always blocked (system directories)
        # These are in addition to the built-in denylist
        denied_directories: []
        # Maximum number of files to return in a scan
        max_files_per_scan: 10000
        # Timeout for scan operations (seconds)
        scan_timeout_seconds: 30
        # Allowed origins for CORS and WebSocket connections
        # Empty = same-origin only (most secure)
        # "*" = allow all origins (use only for local development)
        # Specific origins: ["http://localhost:3000", "http://localhost:8080"]
        allowed_origins: []
scrapers:
    user_agent: Javinizer (+https://github.com/javinizer/Javinizer)
    priority:
        - r18dev
        - dmm
    # HTTP/SOCKS5 proxy for all scraper requests (optional)
    proxy:
        enabled: false
        url: ""  # Examples: "http://proxy.example.com:8080", "socks5://localhost:1080"
        username: ""  # Optional authentication
        password: ""  # Optional authentication
    r18dev:
        enabled: true
    dmm:
        enabled: true
        scrape_actress: false
        enable_headless: true
        headless_timeout: 30
metadata:
    priority:
        actress:
            - dmm
            - r18dev
        original_title:
            - dmm
            - r18dev
        cover_url:
            - dmm
            - r18dev
        description:
            - dmm
            - r18dev
        director:
            - dmm
            - r18dev
        genre:
            - dmm
            - r18dev
        id:
            - dmm
            - r18dev
        content_id:
            - dmm
            - r18dev
        label:
            - dmm
            - r18dev
        maker:
            - dmm
            - r18dev
        poster_url:
            - r18dev
            - dmm
        rating:
            - dmm
            - r18dev
        release_date:
            - dmm
            - r18dev
        runtime:
            - dmm
            - r18dev
        series:
            - dmm
            - r18dev
        screenshot_url:
            - dmm
            - r18dev
        title: []
        trailer_url:
            - dmm
            - r18dev
    # Actress image database (SQLite-backed)
    actress_database:
        enabled: true
        auto_add: true        # Automatically add new actresses to database
        convert_alias: false  # Convert actress names using alias database

    # Genre replacement/normalization database (SQLite-backed)
    genre_replacement:
        enabled: true
        auto_add: true  # Automatically add new genres with identity mapping (genre -> genre)

    # Per-movie tag database (SQLite-backed)
    # Allows adding custom tags to individual movies (appears in NFO files)
    tag_database:
        enabled: false  # Enable per-movie tag lookup (opt-in feature)

    # Genres to ignore/filter out. Supports both exact strings and regex patterns.
    # Patterns starting with ^, ending with $, or containing regex metacharacters are treated as regex.
    # Examples:
    #   - "Sample"           # Exact match
    #   - "^Featured"        # Starts with "Featured"
    #   - ".*mosaic.*"       # Contains "mosaic"
    #   - "^(HD|4K|VR)"      # Starts with HD, 4K, or VR
    #   - "(?i)uncensored"   # Case-insensitive match for "uncensored"
    ignore_genres: []
    # ignore_genres:
    #   - "^Featured Actress"
    #   - ".*mosaic.*"
    #   - "Sample"
    #   - "Trailer"
    required_fields: []
    nfo:
        enabled: true
        display_name: <TITLE>
        filename_template: <ID>.nfo
        first_name_order: true
        actress_language_ja: false
        unknown_actress_text: Unknown
        actress_as_tag: false
        add_generic_role: false  # Add generic "Actress" role to all actresses
        alt_name_role: false     # Use alternate name (Japanese) in role field
        include_originalpath: false  # Include source filename in NFO
        include_stream_details: false
        include_fanart: true
        include_trailer: true
        rating_source: r18dev
        tag: []
        tagline: ""
        credits: []
file_matching:
    extensions:
        - .mp4
        - .mkv
        - .avi
        - .wmv
        - .flv
    min_size_mb: 0
    exclude_patterns:
        - '*-trailer*'
        - '*-sample*'
    regex_enabled: false
    regex_pattern: ([a-zA-Z|tT28]+-\d+[zZ]?[eE]?)(?:-pt)?(\d{1,2})?
output:
    folder_format: <ID> [<STUDIO>] - <TITLE> (<YEAR>)
    file_format: <ID>
    subfolder_format: []
    delimiter: ', '
    download_cover: true
    download_poster: true
    download_extrafanart: true
    download_trailer: true
    download_actress: true
    # Separate proxy for downloads (optional - leave disabled to use no proxy for downloads)
    download_proxy:
        enabled: false
        url: ""  # Leave empty or set to use a different proxy than scrapers
        username: ""
        password: ""
database:
    type: sqlite
    dsn: data/javinizer.db
logging:
    level: info
    format: text
    output: stdout
performance:
    max_workers: 5
    worker_timeout: 300
    buffer_size: 100
    update_interval: 100

# MediaInfo configuration for video metadata extraction
mediainfo:
    # Enable MediaInfo CLI fallback for unsupported formats (WMV, ASF, exotic containers)
    # Requires 'mediainfo' binary installed on system (https://mediaarea.net/MediaInfo)
    # Native Go parsers handle: MP4, MOV, MKV, AVI, FLV
    cli_enabled: false

    # Path to mediainfo binary (default: searches system PATH)
    # Examples: "mediainfo", "/usr/local/bin/mediainfo", "C:\\Program Files\\MediaInfo\\MediaInfo.exe"
    cli_path: "mediainfo"

    # Timeout for CLI execution in seconds (default: 30)
    cli_timeout: 30
