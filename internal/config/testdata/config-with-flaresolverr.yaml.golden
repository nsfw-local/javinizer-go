# Golden file for testing config round-trip with flaresolverr
# Tests that global flaresolverr block is preserved in YAML round-trip

scrapers:
    user_agent: Javinizer-Test/1.0
    referer: https://www.dmm.co.jp/
    timeout_seconds: 30
    request_timeout_seconds: 60
    priority:
        - r18dev
        - dmm
    flaresolverr:
        enabled: true
        url: "http://localhost:8191/v1"
        timeout: 30
        max_retries: 3
        session_ttl: 300
    proxy:
        enabled: true
        default_profile: ""
        profiles: {}
    r18dev:
        enabled: true
        language: en
        request_delay: 1500
        max_retries: 3
        respect_retry_after: true
        user_agent: ""
        use_flaresolverr: true
    dmm:
        enabled: true
        use_browser: true
        scrape_actress: true
