# Golden file for testing config round-trip with scraper-specific fields
# Tests that per-scraper unique fields are preserved in YAML round-trip

scrapers:
    user_agent: Javinizer-Scraper-Test/1.0
    referer: https://www.dmm.co.jp/
    timeout_seconds: 45
    request_timeout_seconds: 90
    priority:
        - r18dev
        - dmm
        - javlibrary
    flaresolverr:
        enabled: false
        url: ""
        timeout: 30
        max_retries: 3
        session_ttl: 300
    proxy:
        enabled: false
        default_profile: ""
        profiles: {}
    r18dev:
        enabled: true
        language: en
        request_delay: 2000
        max_retries: 5
        respect_retry_after: true
        user_agent: ""
    dmm:
        enabled: true
        use_browser: true
        scrape_actress: true
    javlibrary:
        enabled: true
        language: en
        base_url: "https://javlibrary.com"
        user_agent: ""
